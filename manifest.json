{
  "manifest_version": 3,
  "name": "UltraBlock — Ultimate Ad Blocker",
  "version": "2.5.0",
  "description": "Stealth-grade ad blocker with Cookie Negotiator, Dark Pattern Neutralizer, Dopamine Detox, Tracker Poisoning, Retro Mode, SponsorBlock, Anti-Circumvention, and UserScript Engine.",

  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "declarativeNetRequestFeedback",
    "scripting",
    "storage",
    "tabs",
    "webNavigation",
    "alarms",
    "unlimitedStorage"
  ],

  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "src/background/background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/anti-circumvention.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/webrtc-protect.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/stealth.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/tracker-poison.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/media-pruning.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/content/content.js",
        "src/content/cookie-negotiator.js",
        "src/content/dark-patterns.js",
        "src/content/dopamine-detox.js",
        "src/content/retro-mode.js",
        "src/content/userscript-engine.js"
      ],
      "css": ["src/styles/cosmetic.css"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/removeparam.js", "src/content/element-picker.js", "src/content/epicker-full.js", "src/content/procedural-cosmetic.js", "src/content/adnauseam-detector.js", "src/content/perceptual-ad-detection.js"],
      "run_at": "document_end",
      "all_frames": false
    },
    {
      "matches": ["*://*.youtube.com/*", "*://youtube.com/*"],
      "js": ["src/content/youtube.js", "src/content/video-patch.js", "src/content/sponsorblock.js", "src/content/sponsorblock-compiled.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["*://*.twitch.tv/*", "*://twitch.tv/*"],
      "js": ["src/content/video-patch.js", "src/content/media-pruning.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "declarative_net_request": {
    "rule_resources": [
      { "id": "ad_networks",    "enabled": true, "path": "rules/ad_networks.json" },
      { "id": "trackers",       "enabled": true, "path": "rules/trackers.json"    },
      { "id": "malware",        "enabled": true, "path": "rules/malware.json"     },
      { "id": "annoyances",     "enabled": true, "path": "rules/annoyances.json"  },
      { "id": "cname_trackers", "enabled": true, "path": "rules/cname-trackers.json" }
    ]
  },

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "commands": {
    "toggle-retro": {
      "suggested_key": { "default": "Ctrl+Shift+E" },
      "description": "Toggle Retro Mode"
    }
  },

  "web_accessible_resources": [
    {
      "resources": [
        "src/redirects/*",
        "src/redirects/ublock/*",
        "src/pages/blocked.html",
        "src/pages/site-switches.html",
        "src/pages/site-switches.js",
        "src/pages/statistics.html",
        "src/pages/statistics.js",
        "src/pages/filters.html",
        "src/pages/filters.js",
        "src/pages/profiles.html",
        "src/pages/profiles.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
